rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /analyses/{analysisId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if (request.auth != null && request.auth.uid == request.resource.data.userId)
                    || (request.auth == null && request.resource.data.userId == null);
      allow update, delete: if false;
    }
    // Only the dedicated server service-user (see server/firebaseServerAuth.js)
    // may read/write subscriptions — update this email if you change
    // FIREBASE_SERVICE_EMAIL, and redeploy rules after any change.
    match /subscriptions/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.token.email == "experiments@genuinecro.com";
    }
    // Aggregate, anonymized cross-account benchmark figures (no user/site
    // identifiers) — only the server service-user computes and writes these.
    match /benchmarks/{category} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.auth.token.email == "experiments@genuinecro.com";
    }
    // Client-driven scan status (start "scanning", flip to "complete" once
    // the same tab's analysis request resolves) — lets the Dashboard show
    // in-progress scans across reloads and other tabs/devices.
    match /scanJobs/{jobId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]);
      allow delete: if false;
    }
    match /actionItems/{itemId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "resolvedAt", "userEvidence"]);
      allow delete: if false;
    }
    // Per-site business inputs (monthly traffic, AOV, baseline conversion rate)
    // used to turn a friction point's estimated % lift into a revenue estimate.
    // One doc per user+domain, keyed deterministically (see siteSettings.ts).
    match /siteSettings/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }
    // Log of monitoring "check now" runs that found a score drop or a new
    // critical issue — immutable, owner-only.
    match /monitoringAlerts/{alertId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }
    // A snapshot of one audit report, made public on-demand via a "Share"
    // action. Publicly readable by design (the doc ID is the unguessable
    // share link) — only the owner may create or revoke (delete) one.
    match /sharedReports/{shareId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
